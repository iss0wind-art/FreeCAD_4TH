# 🏗️ FreeCAD_4th 환경 변수 설정 가이드 (.env.example)
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.

# [필수] Gemini API 설정
# 구글 AI 스튜디오(https://aistudio.google.com/)에서 발급받은 키를 입력하세요.
GEMINI_API_KEY=your_gemini_api_key_here

# [선택] Turso (LibSQL) 데이터베이스 설정
# 클라우드 DB를 사용하지 않을 경우 비워두면 자동으로 로컬 SQLite(output/boq.db)를 사용합니다.
TURSO_URL=
TURSO_AUTH_TOKEN=

# [기타] 시스템 설정
# DEBUG=True
# LOG_LEVEL=INFO
